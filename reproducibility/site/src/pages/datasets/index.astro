---
import Default from "../../layouts/Default.astro";
import datasets from "../../data/datasets.json";
---

<Default title="Datasets" description="All IR benchmarks tracked in the leaderboard.">
  <h1 class="text-2xl font-bold md:text-3xl">Datasets</h1>
  <p class="mt-2 text-qg-fg-muted">
    Every dataset is registered in <code class="qg-mono">dataset_registry.yaml</code>.
    Click through for a per-dataset leaderboard.
  </p>

  <ul class="mt-6 grid gap-3 md:grid-cols-2">
    {
      datasets.map((d: any) => (
        <li class="rounded-lg border border-qg-border p-4 hover:bg-qg-bg-soft">
          <a href={`/datasets/${d.id}`} class="block">
            <div class="flex items-baseline justify-between gap-2">
              <span class="font-semibold">{d.name}</span>
              <span class="text-xs text-qg-fg-muted">
                {d.run_count} run{d.run_count === 1 ? "" : "s"}
              </span>
            </div>
            <div class="mt-1 qg-mono text-xs text-qg-fg-muted">{d.id}</div>
            <div class="mt-2 text-xs text-qg-fg-muted">
              metrics: {d.eval_metrics.join(", ")}
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</Default>
