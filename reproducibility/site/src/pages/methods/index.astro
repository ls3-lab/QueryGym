---
import Default from "../../layouts/Default.astro";
import EmptyState from "../../components/EmptyState.astro";
import methods from "../../data/methods.json";
---

<Default title="Methods" description="Reformulation methods with results in the leaderboard.">
  <h1 class="text-2xl font-bold md:text-3xl">Methods</h1>
  <p class="mt-2 text-qg-fg-muted">
    Methods derived from runs landed in the leaderboard. The full method registry
    lives in the package itself.
  </p>

  {
    methods.length === 0 ? (
      <div class="mt-8"><EmptyState /></div>
    ) : (
      <ul class="mt-6 grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        {methods.map((m: any) => (
          <li class="rounded-lg border border-qg-border p-4 hover:bg-qg-bg-soft">
            <div class="font-semibold qg-mono">{m.id}</div>
            <div class="mt-1 text-xs text-qg-fg-muted">
              {m.run_count} run{m.run_count === 1 ? "" : "s"}
            </div>
          </li>
        ))}
      </ul>
    )
  }
</Default>
