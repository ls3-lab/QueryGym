---
import methods from "../data/methods.json";

interface Props {
  /** Section variant: "compact" (3-up, smaller) or "full" (3-up, with paper links). */
  variant?: "compact" | "full";
}

const { variant = "full" } = Astro.props;
---

<ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
  {
    methods.map((m: any) => (
      <li class="qg-card">
        <div class="flex items-baseline justify-between">
          <h3 class="text-lg font-semibold">{m.name}</h3>
          <code class="qg-mono text-xs text-qg-fg-muted">{m.id}</code>
        </div>
        <p class="mt-2 text-sm text-qg-fg-muted">{m.tagline}</p>
        {variant === "full" && m.paper_url && (
          <a
            class="mt-3 inline-block text-xs font-medium text-qg-accent hover:underline"
            href={m.paper_url}
            target="_blank"
            rel="noopener noreferrer"
          >
            {m.paper} ↗
          </a>
        )}
      </li>
    ))
  }
</ul>
